# ===========================================
# 员工管理系统 - Git 忽略规则
# ===========================================

# ---- 前端依赖 ----
node_modules/

# ---- Java/Maven 编译输出 ----
target/
*.class
*.jar
*.war
*.ear

# ---- IDE 配置 ----
.idea/
.vscode/
*.iml
*.iws
*.ipr
out/

# ---- 构建产物 ----
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- 环境变量 ----
.env
.env.local
.env.*.local
.env.production

# ---- 操作系统文件 ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- 临时文件 ----
*.tmp
*.temp
*.swp
*~
~*

# ---- 测试覆盖率 ----
coverage/
.nyc_output/
*.lcov

# ---- 缓存 ----
.cache/
.parcel-cache/
.eslintcache